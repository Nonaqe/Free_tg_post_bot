# --- Обязательно ---
BOT_TOKEN=123456:ABC-DEF_token_here

# ID каналов-источников через запятую (бот должен быть участником)
SOURCE_CHANNEL_IDS=-100123456789

# ID администраторов через запятую (первый = superadmin при старте)
ADMIN_IDS=12345678

# --- Опционально ---
DATABASE_URL=sqlite:///bot.db
DEFAULT_DELAY_MINUTES=30
SCHEDULER_INTERVAL_SECONDS=60
RETRY_ATTEMPTS=3

# Чат для алертов/уведомлений (можно задать позже через админку)
NOTIFY_CHAT_ID=

# --- Webhook (опционально; пусто = polling) ---
# Публичный HTTPS-адрес сервера. Если задан — бот работает через webhook.
WEBHOOK_BASE_URL=
WEBHOOK_PATH=/webhook
WEBHOOK_SECRET=
WEBAPP_HOST=0.0.0.0
WEBAPP_PORT=8080
